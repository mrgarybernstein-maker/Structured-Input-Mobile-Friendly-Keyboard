{
  "title": "Book an appointment",
  "subtitle": "Please fill in all fields marked with *",
  "submitLabel": "Continue",

  "fields": [
    {
      "id":       "firstname",
      "label":    "* First name",
      "type":     "alpha-full",
      "required": true
    },
    {
      "id":       "lastname",
      "label":    "* Last name",
      "type":     "alpha-full",
      "required": true
    },
    {
      "id":          "email",
      "label":       "Email",
      "type":        "free-full",
      "placeholder": "your@email.com",
      "required":    false
    },
    {
      "id":          "emailconfirm",
      "label":       "Email confirmation",
      "type":        "free-full",
      "placeholder": "your@email.com",
      "required":    false
    },
    {
      "id":       "dob",
      "label":    "* Date of birth",
      "type":     "split",
      "pattern":  "NN-MMM-NNNN",
      "required": true
    },
    {
      "id":       "mobile",
      "label":    "Mobile",
      "type":     "split",
      "pattern":  "NNN NNN NNNN",
      "required": false
    },
    {
      "id":       "ramq",
      "label":    "Health Insurance Number (RAMQ)",
      "type":     "split",
      "pattern":  "AAAA NNNNNN NN",
      "required": false
    }
  ],

  "optionSets": {
    "provinces": [
      { "value": "AB", "label": "AB – Alberta" },
      { "value": "BC", "label": "BC – British Columbia" },
      { "value": "MB", "label": "MB – Manitoba" },
      { "value": "NB", "label": "NB – New Brunswick" },
      { "value": "NL", "label": "NL – Newfoundland & Labrador" },
      { "value": "NS", "label": "NS – Nova Scotia" },
      { "value": "NT", "label": "NT – Northwest Territories" },
      { "value": "NU", "label": "NU – Nunavut" },
      { "value": "ON", "label": "ON – Ontario" },
      { "value": "PE", "label": "PE – Prince Edward Island" },
      { "value": "QC", "label": "QC – Québec" },
      { "value": "SK", "label": "SK – Saskatchewan" },
      { "value": "YT", "label": "YT – Yukon" }
    ]
  }
}
